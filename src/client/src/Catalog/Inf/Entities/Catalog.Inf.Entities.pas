  public
    [AutoGenerated]
    [Column('Id', [cpPrimaryKey])]
    property Id: TGuid read FId write FId;
    [Column('Name', [cpRequired])]
    property Name: string read FName write FName;
  end;

  [Entity]
  [Table('[attribute_codes]', '[catalog]')]
  TAttributeCodeEntity = class(TEntity)
  private
    FId: TGuid;
    FCode: string;
    FCodeType: string;
    FAttributeId: TGuid;
  private
    [ManyToOne(False, [ckCascadeAll], 'Id')]
    FAttribute: TAttributeEntity;
  public
    [AutoGenerated]
    [Column('Id', [cpPrimaryKey])]
    property Id: TGuid read FId write FId;
    [Column('Code', [cpRequired])]
    property Code: string read FCode write FCode;
    [Column('CodeType', [cpRequired])]
    property CodeType: string read FCodeType write FCodeType;
    [Column('AttributeId', [cpRequired])]
    [ForeignJoinColumn('AttributeId', '[catalog].[attributes]', 'Id')]
    property AttributeId: TGuid read FAttributeId write FAttributeId;
  public
    property Attribute: TAttributeEntity read FAttribute;
  end;

  TGridEntity = class;

  [Entity]
  [Table('[variants]', '[catalog]')]
  TVariantEntity = class(TEntity)
  private
    FId: TGuid;
    FSKU: string;
    FGtin: Nullable<string>;
    FActive: Boolean;
    FProductId: TGuid;
    function GetGridValues: IList<TGridEntity>;
  private
    [OneToMany(False, [ckCascadeAll])]
    FGridValues: Lazy<IList<TGridEntity>>;
  public
    [AutoGenerated]
    [Column('Id', [cpPrimaryKey])]
    property Id: TGuid read FId write FId;
    [Column('SKU', [cpRequired])]
    property SKU: string read FSKU write FSKU;
    [Column('Gtin')]
    property Gtin: Nullable<string> read FGtin write FGtin;
    [Column('Active', [cpRequired])]
    property Active: Boolean read FActive write FActive;
    [Column('ProductId', [cpRequired])]
    [ForeignJoinColumn('ProductId', '[catalog].[products]', 'Id')]
    property ProductId: TGuid read FProductId write FProductId;
  public
    property GridValues: IList<TGridEntity> read GetGridValues;
  end;

  [Entity]
  [Table('[grids]', '[catalog]')]
  TGridEntity = class(TEntity)
  private
    FId: TGuid;
    FVariantId: TGuid;
    FColumnId: TGuid;
    FValue: string;
  private
    [ManyToOne(False, [ckCascadeAll], 'Id')]
    FColumn: TColumnEntity;
    [ManyToOne(False, [ckCascadeAll], 'Id')]
    FVariant: TVariantEntity;
  public
    [AutoGenerated]
    [Column('Id', [cpPrimaryKey])]
    property Id: TGuid read FId write FId;
    [Column('VariantId', [cpRequired])]
    [ForeignJoinColumn('VariantId', '[catalog].[variants]', 'Id')]
    property VariantId: TGuid read FVariantId write FVariantId;
    [Column('ColumnId', [cpRequired])]
    [ForeignJoinColumn('ColumnId', '[catalog].[columns]', 'Id')]
    property ColumnId: TGuid read FColumnId write FColumnId;
    [Column('Value', [cpRequired])]
    property Value: string read FValue write FValue;
  public
    property Column: TColumnEntity read FColumn;
    property Variant: TVariantEntity read FVariant;
  end;

  [Entity]
  [Table('[services]', '[catalog]')]
  TServiceEntity = class(TItemEntity)
  public
    constructor Create;
  end;

implementation

{ TItemEntity }

procedure TItemEntity.SetItemTypeId(const AValue: TGuid);
begin
  FItemTypeId := AValue;
end;

{ TProductEntity }

constructor TProductEntity.Create;
begin
  inherited Create;
  SetItemTypeId(TSystemCatalog.ProductTypeId);
end;

function TProductEntity.GetColumns: IList<TColumnEntity>;
begin
  Result := FColumns;
end;

function TProductEntity.GetConversions: IList<TConversionEntity>;
begin
  Result := FConversions;
end;

function TProductEntity.GetVariants: IList<TVariantEntity>;
begin
  Result := FVariants;
end;

{ TVariantEntity }

function TVariantEntity.GetGridValues: IList<TGridEntity>;
begin
  Result := FGridValues;
end;

{ TServiceEntity }

constructor TServiceEntity.Create;
begin
  inherited Create;
  SetItemTypeId(TSystemCatalog.ServiceTypeId);
end;

end.
