          'WHEN MATCHED THEN'
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Masculino'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@GdrMaleId, '#39'Masculino'#39', @GdrGenderId)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN'
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);')
      end
      item
        Name = 'countries'
        SQL.Strings = (
          '/*'
          '    Objetivo:'
          '    ----------'
          '    Garantir que o pa'#237's "Brasil" exista na tabela'
          '    [address].[countries], com Id fixo e DialCode = +55.'
          ''
          '    Regras:'
          '    -------'
          '    - Usa Name = '#39'Brasil'#39' como chave l'#243'gica'
          '    - Se j'#225' existir, n'#227'o altera o registro'
          '    - Se n'#227'o existir, insere com Id pr'#233'-definido'
          '    - Script idempotente'
          '*/'
          ''
          'DECLARE @CountryId UNIQUEIDENTIFIER;'
          ''
          'SET @CountryId = :CountryId;'
          ''
          'MERGE INTO [country].[countries] AS T'
          'USING (VALUES ('
          '    @CountryId, -- Id'
          '    N'#39'Brasil'#39',  -- Name'
          '    N'#39'+55'#39'      -- DialCode'
          ')) AS S (Id, Name, DialCode)'
          'ON T.Name = S.Name'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, DialCode)'
          '    VALUES (S.Id, S.Name, S.DialCode);')
      end
      item
        Name = 'country_codes'
        SQL.Strings = (
          '/*'
          '    Seed de c'#243'digos do Brasil:'
          '    --------------------------'
          '    ISO2    = BR'
          '    ISO3    = BRA'
          '    NUMERIC = 076'
          '    IBGE    = 1058'
          '    BACEN   = 076'
          '*/'
          ''
          'DECLARE @CountryId UNIQUEIDENTIFIER;'
          ''
          'SET @CountryId = :CountryId;'
          ''
          'INSERT INTO [country].[codes] ('
          '    CountryId,'
          '    CodeType,'
          '    Code'
          ')'
          'SELECT'
          '    @CountryId, -- Brasil'
          '    V.CodeType,'
          '    V.Code'
          'FROM (VALUES'
          '    ('#39'ISO2'#39',    '#39'BR'#39'),'
          '    ('#39'ISO3'#39',    '#39'BRA'#39'),'
          '    ('#39'NUMERIC'#39', '#39'076'#39'),'
          '    ('#39'IBGE'#39',    '#39'1058'#39'),'
          '    ('#39'BACEN'#39',   '#39'076'#39')'
          ') V (CodeType, Code)'
          'WHERE NOT EXISTS ('
          '    SELECT 1'
          '    FROM [country].[codes] C'
          '    WHERE C.CountryId = @CountryId'
          '      AND C.CodeType  = V.CodeType'
          ');')
      end
      item
        Name = 'nationalities'
        SQL.Strings = (
          '/*'
          '    Seed: Nacionalidade Brasileiro'
          '    ------------------------------'
          '    - Name      = '#39'Brasileiro'#39
          '    - CountryId = Brasil'
          '    - Script idempotente via MERGE'
          '*/'
          ''
          'DECLARE @CountryId UNIQUEIDENTIFIER;'
          ''
          'SET @CountryId = :CountryId;'
          ''
          ';MERGE INTO [country].[nationalities] AS T'
          'USING (VALUES ('
          '    N'#39'Brasileiro'#39',           -- Name'
          '    @CountryId               -- CountryId (Brasil)'
          ')) AS S (Name, CountryId)'
          'ON  T.CountryId = S.CountryId'
          'AND T.Name      = S.Name'
          'WHEN MATCHED THEN'
          '    UPDATE SET'
          '        T.CountryId = S.CountryId,'
          '        T.Name      = S.Name'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Name, CountryId)'
          '    VALUES (S.Name, S.CountryId);')
      end
      item
        Name = 'states'
        SQL.Strings = (
          '/*'
          '    Seed: Estados Brasileiros'
          '*/'
          ''
          'DECLARE @CountryId UNIQUEIDENTIFIER;'
          ''
          'SET @CountryId = :CountryId;'
          ''
          '-- Acre'
          'MERGE INTO [address].[states] AS T'
          'USING (VALUES ('
          '    '#39'49A7433E-F36B-1410-871D-007892B87384'#39','
          '    N'#39'Acre'#39', N'#39'AC'#39','
          '    @CountryId'
          ')) AS S (Id, Name, Acronym, CountryId)'
          'ON T.Id = S.Id'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, Acronym, CountryId)'
          '    VALUES (S.Id, S.Name, S.Acronym, S.CountryId);'
          ''
          '-- Alagoas'
          'MERGE INTO [address].[states] AS T'
          'USING (VALUES ('
          '    '#39'4CA7433E-F36B-1410-871D-007892B87384'#39','
          '    N'#39'Alagoas'#39', N'#39'AL'#39','
          '    @CountryId'
          ')) AS S (Id, Name, Acronym, CountryId)'
          'ON T.Id = S.Id'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, Acronym, CountryId)'
          '    VALUES (S.Id, S.Name, S.Acronym, S.CountryId);'
          ''
          '-- Amap'#225
          'MERGE INTO [address].[states] AS T'
          'USING (VALUES ('
          '    '#39'4FA7433E-F36B-1410-871D-007892B87384'#39','
          '    N'#39'Amap'#225#39', N'#39'AP'#39','
          '    @CountryId'
          ')) AS S (Id, Name, Acronym, CountryId)'
          'ON T.Id = S.Id'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, Acronym, CountryId)'
          '    VALUES (S.Id, S.Name, S.Acronym, S.CountryId);'
          ''
          '-- Amazonas'
          'MERGE INTO [address].[states] AS T'
          'USING (VALUES ('
          '    '#39'52A7433E-F36B-1410-871D-007892B87384'#39','
          '    N'#39'Amazonas'#39', N'#39'AM'#39','
          '    @CountryId'
          ')) AS S (Id, Name, Acronym, CountryId)'
          'ON T.Id = S.Id'
          'WHEN NOT MATCHED THEN'
