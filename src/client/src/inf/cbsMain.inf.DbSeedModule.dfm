      item
        Name = 'state_codes'
        SQL.Strings = (
          '/*'
          '    Seed completo de c'#243'digos dos Estados brasileiros'
          '    Tabela: address.state_codes'
          ''
          '    CodeTypes:'
          '      - IBGE'
          '      - ISO2'
          '      - ISO3166-2'
          '*/'
          ''
          'DECLARE @StateId UNIQUEIDENTIFIER;'
          ''
          'SET @StateId = '#39'49A7433E-F36B-1410-871D-007892B87384'#39';'
          ''
          '--------------------------------------------------'
          '-- AC - Acre (01)'
          '--------------------------------------------------'
          'INSERT INTO [address].[state_codes] ('
          '    StateId, '
          '    CodeType, '
          '    Code'
          ')'
          'SELECT'
          '    @StateId,'
          '    V.CodeType,'
          '    V.Code'
          'FROM (VALUES'
          '    ('#39'IBGE'#39', '#39'12'#39'),'
          '    ('#39'ISO2'#39', '#39'AC'#39'),'
          '    ('#39'ISO3166-2'#39', '#39'BR-AC'#39')'
          ') V (CodeType, Code)'
          'WHERE NOT EXISTS ('
          '    SELECT 1 FROM [address].[state_codes]'
          '    WHERE StateId = @StateId'
          '      AND CodeType = V.CodeType'
          ');'
          ''
          'SET @StateId = '#39'4CA7433E-F36B-1410-871D-007892B87384'#39';'
          ''
          '--------------------------------------------------'
          '-- AL - Alagoas (02)'
          '--------------------------------------------------'
          'INSERT INTO [address].[state_codes] ('
          '    StateId, '
          '    CodeType, '
          '    Code'
          ')'
          'SELECT '
          '    @StateId, '
          '    V.CodeType, '
          '    V.Code'
          'FROM (VALUES'
          '    ('#39'IBGE'#39','#39'27'#39'), '
          '    ('#39'ISO2'#39','#39'AL'#39'), '
          '    ('#39'ISO3166-2'#39','#39'BR-AL'#39')'
          ') V (CodeType, Code)'
          'WHERE NOT EXISTS ('
          '    SELECT 1 FROM [address].[state_codes]'
          '    WHERE StateId = @StateId'
          '      AND CodeType = V.CodeType'
          ');'
          ''
          'SET @StateId = '#39'4FA7433E-F36B-1410-871D-007892B87384'#39';'
          ''
          '--------------------------------------------------'
          '-- AP - Amap'#225' (03)'
          '--------------------------------------------------'
