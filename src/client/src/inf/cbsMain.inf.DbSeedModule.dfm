      item
        Name = 'generos'
        SQL.Strings = (
          '---------------------------------------------------------'
          '-- CATEGORIAS: SEXO'
          '--'
          '-- Hierarquia:'
          '--   Sexo'
          '--       '#9500#9472#9472' Feminino'
          '--       '#9492#9472#9472' Masculino'
          '--'
          '-- GUIDs utilizados:'
          '--   GdrGenderId = 34A7433E-F36B-1410-871D-007892B87384'
          '--   GdrFemale   = 3CA7433E-F36B-1410-871D-007892B87384'
          '--   GdrMaleId   = 40A7433E-F36B-1410-871D-007892B87384'
          '---------------------------------------------------------'
          ''
          
            'DECLARE @GdrGenderId    UNIQUEIDENTIFIER = '#39'34A7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          
            'DECLARE @GdrFemaleId    UNIQUEIDENTIFIER = '#39'3CA7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          
            'DECLARE @GdrMaleId      UNIQUEIDENTIFIER = '#39'40A7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          ''
          '---------------------------------------------------------'
          '-- Sexo (Pai)'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@GdrGenderId, '#39'Sexo'#39', NULL)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name'
          'WHEN NOT MATCHED THEN '
