          'FROM (VALUES'
          '    ('#39'IBGE'#39','#39'16'#39'), '
          '    ('#39'ISO2'#39','#39'AP'#39'), '
          '    ('#39'ISO3166-2'#39','#39'BR-AP'#39')'
          ') V (CodeType, Code)'
          'WHERE NOT EXISTS ('
          '    SELECT 1 FROM [address].[state_codes]'
