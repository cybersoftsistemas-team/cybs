      item
        Name = 'emails'
        SQL.Strings = (
          '---------------------------------------------------------'
          '-- CATEGORIAS: EMAILS'
          '--'
          '-- Hierarquia:'
          '--   Emails'
          '--       '#9500#9472#9472' Email'
          '--       '#9500#9472#9472' Email 2'
          '--       '#9492#9472#9472' Outro'
          '--'
          '-- GUIDs utilizados:'
          '--   ElsEmailsId = FCA6433E-F36B-1410-871D-007892B87384'
          '--   ElsEmailId  = FEA6433E-F36B-1410-871D-007892B87384'
          '--   ElsEmail2Id = 01A7433E-F36B-1410-871D-007892B87384'
          '--   ElsOtherId  = 02A7433E-F36B-1410-871D-007892B87384'
          '---------------------------------------------------------'
          ''
          
            'DECLARE @ElsEmailsId UNIQUEIDENTIFIER = '#39'FCA6433E-F36B-1410-871D' +
            '-007892B87384'#39';'
          
            'DECLARE @ElsEmailId  UNIQUEIDENTIFIER = '#39'FEA6433E-F36B-1410-871D' +
            '-007892B87384'#39';'
          
            'DECLARE @ElsEmail2Id UNIQUEIDENTIFIER = '#39'01A7433E-F36B-1410-871D' +
            '-007892B87384'#39';'
          
            'DECLARE @ElsOtherId  UNIQUEIDENTIFIER = '#39'02A7433E-F36B-1410-871D' +
            '-007892B87384'#39';'
          ''
          '---------------------------------------------------------'
          '-- Emails (Pai)'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@ElsEmailsId, '#39'Emails'#39', NULL)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name'
          'WHEN NOT MATCHED THEN '
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Email'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@ElsEmailId, '#39'Email'#39', @ElsEmailsId)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN'
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Email 2'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@ElsEmail2Id, '#39'Email 2'#39', @ElsEmailsId)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN'
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Outro'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@ElsOtherId, '#39'Outro'#39', @ElsEmailsId)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN'
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN'
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);')
      end
      item
        Name = 'endereco'
        SQL.Strings = (
          '---------------------------------------------------------'
          '-- CATEGORIAS DE ENDERE'#199'O'
          '-- Estrutura Hier'#225'rquica:'
          '--   Endere'#231'o'
          '--     '#9500#9472#9472' Comercial'
          '--     '#9500#9472#9472' Residencial'
          '--     '#9492#9472#9472' Outro'
          '--'
          '-- GUIDs utilizados:'
          '--   AdrAddress     = 08A7433E-F36B-1410-871D-007892B87384'
          '--   AdrBusinessId  = 0AA7433E-F36B-1410-871D-007892B87384'
          '--   AdrHomeId      = 0DA7433E-F36B-1410-871D-007892B87384'
          '--   AdrOtherId     = 10A7433E-F36B-1410-871D-007892B87384'
          '---------------------------------------------------------'
          ''
          
            'DECLARE @AdrAddress     UNIQUEIDENTIFIER = '#39'08A7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          
            'DECLARE @AdrBusinessId  UNIQUEIDENTIFIER = '#39'0AA7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          
            'DECLARE @AdrHomeId      UNIQUEIDENTIFIER = '#39'0DA7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          
            'DECLARE @AdrOtherId     UNIQUEIDENTIFIER = '#39'10A7433E-F36B-1410-8' +
            '71D-007892B87384'#39';'
          ''
          '---------------------------------------------------------'
          '-- Endere'#231'o (Pai)'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@AdrAddress, '#39'Endere'#231'o'#39', NULL)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name'
          'WHEN NOT MATCHED THEN '
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Comercial'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@AdrBusinessId, '#39'Comercial'#39', @AdrAddress)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN '
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Residencial'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@AdrHomeId, '#39'Residencial'#39', @AdrAddress)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN '
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);'
          ''
          '---------------------------------------------------------'
          '-- Outro'
          '---------------------------------------------------------'
          'MERGE INTO general.categories AS T'
          'USING (VALUES '
          '    (@AdrOtherId, '#39'Outro'#39', @AdrAddress)'
          ') AS S (Id, Name, ParentId)'
          'ON T.Id = S.Id'
          'WHEN MATCHED THEN '
          '    UPDATE SET Name = S.Name, ParentId = S.ParentId'
          'WHEN NOT MATCHED THEN '
          '    INSERT (Id, Name, ParentId)'
          '    VALUES (S.Id, S.Name, S.ParentId);')
      end
